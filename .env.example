# ===========================================
# NCN System Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# Node Environment
NODE_ENV=production
PORT=3001

# ===========================================
# Database Configuration (MS SQL Server)
# ===========================================
DB_HOST=your-sql-server-host
DB_PORT=1433
DB_NAME=NCN_Database
DB_USER=your-db-username
DB_PASSWORD=your-db-password

# ===========================================
# LDAP/Active Directory Configuration
# ===========================================
LDAP_URL=ldap://your-ad-server.domain.com:389
LDAP_BASE_DN=DC=domain,DC=com
LDAP_BIND_DN=CN=service-account,OU=Service Accounts,DC=domain,DC=com
LDAP_BIND_CREDENTIALS=your-service-account-password
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# ===========================================
# Session Configuration
# ===========================================
SESSION_SECRET=generate-a-secure-random-string-here

# ===========================================
# Admin Users (comma-separated LAN IDs)
# ===========================================
NCN_ADMIN_LAN_IDS=jason.pang,admin.user

# ===========================================
# SMTP Configuration (for email notifications)
# ===========================================
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=ncn@your-domain.com

# ===========================================
# Application URLs
# ===========================================
# Frontend URL for email links
NCN_APP_URL=http://your-server-ip-or-domain
